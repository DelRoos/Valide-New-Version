# =====================================================================
# Valide School — exemple de variables d'environnement
# =====================================================================
# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est gitignored — JAMAIS le committer.
#
# Les vraies valeurs sont distribuées via le canal sécurisé d'équipe
# (cf. doc/tools/CONTRIBUTING.md § 11).
# =====================================================================

# --- Firebase ---------------------------------------------------------
# Le projet Firebase utilisé par cet environnement.
# Les fichiers google-services.json (Android) et GoogleService-Info.plist (iOS)
# sont placés manuellement dans android/app/ et ios/Runner/.
FIREBASE_PROJECT_ID=valide-dev

# --- Environment ------------------------------------------------------
# Détermine quel backend appeler (émulateur local, dev, staging, prod).
# Valeurs possibles : local | dev | staging | prod
APP_ENV=local

# --- Émulateur Firebase (uniquement APP_ENV=local) --------------------
# Si vrai, le client pointe vers les émulateurs Firebase locaux au lieu
# du backend hébergé.
USE_FIREBASE_EMULATOR=true
FIREBASE_EMULATOR_HOST=localhost

# --- Logging ----------------------------------------------------------
# Niveau de log minimum (debug | info | warning | error)
# En release, forcé à warning quoi qu'il arrive (cf. AppLogger).
LOG_LEVEL=debug

# --- Feature flags locaux (dev uniquement) ----------------------------
# Court-circuiter des features bloquantes pour le dev local.
# En production, ces flags viennent de Firebase Remote Config.
DEV_SKIP_APP_CHECK=false
DEV_USE_MOCK_PAYMENT=false
