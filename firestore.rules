// =====================================================================
// Valide School — Firestore Security Rules (Story 0.9, P0)
// =====================================================================
//
// References :
//   - NFR-9 : "le vrai verrou est dans les regles Firestore" (CLAUDE.md)
//   - ADR-003 : Firebase full backend
//   - doc/partage/BASE-DE-DONNEES.md § users/{uid}
//
// Phase actuelle : P0 squelette minimal. Sera enrichi story par story
// (subscriptions, sessions Mode 2 premium-gated, etc.).
//
// Deploiement : `firebase deploy --only firestore:rules --project=valide-edu`
// Tests : `cd test/rules && npm test` (necessite firebase emulator demarre)
// =====================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------
    // Story 1.15 — Validation panier polymorphe (ADR-016 Decision 4).
    //
    // Version PRAGMATIQUE MVP (Story 1.15 Decision 3) : valide uniquement
    // que `pickedSubjects` est un sous-ensemble de `derivedSubjects`.
    //
    // PAS de validation `obligatorySubjectIds ⊂ pickedSubjects` cote serveur
    // (eviterait une denormalisation `obligatorySubjectIds` sur users/{uid}
    // qui demanderait amender Story 1.3 createProfile + Story 1.13 derive()
    // — scope creep). Trade-off : un bypass client malveillant peut poser
    // `pickedSubjects` sans EN+FR+Math, ce qui casse SON PROPRE profil UX
    // (pas de fuite securite, pas d'escalade privileges). Re-evaluable
    // Epic 2+ via denormalisation.
    //
    // Schema autoritatif : BASE-DE-DONNEES.md § users/{uid}.pickedSubjects.
    // -----------------------------------------------------------------
    function pickedSubjectsValid(data) {
      return data.pickedSubjects is list
        && data.pickedSubjects.toSet().difference(
             data.derivedSubjects.toSet()
           ).size() == 0;
    }

    // -----------------------------------------------------------------
    // Default deny — toute path non matchee ci-dessous est refusee.
    // Firestore deny par defaut deja, mais on l'expose pour lisibilite.
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------
    // users/{uid} — profil eleve, self-only
    // Schema autoritatif : doc/partage/BASE-DE-DONNEES.md § users/{uid}
    // -----------------------------------------------------------------
    match /users/{uid} {

      // Lecture : uniquement le proprietaire
      allow read: if isOwner(uid);

      // Creation : proprietaire + champs critiques valides
      // - subSystem + language figes a l'inscription (cf. ADR-006)
      // - filiere + niveau + serie figes a l'inscription (Story 1.3)
      // - uid redondant doit matcher le doc ID
      // - displayName est string (peut etre vide a la creation, Story 1.6
      //   posera le nom Google/Apple via linkWithCredential)
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.subSystem in ['francophone', 'anglophone']
        && request.resource.data.language in ['fr', 'en']
        && request.resource.data.filiere in ['generale', 'technique']
        && request.resource.data.niveau is string
        && request.resource.data.niveau.size() > 0
        && request.resource.data.serie is string
        && request.resource.data.derivedSubjects is list
        && request.resource.data.examTargets is list
        && request.resource.data.displayName is string;

      // Update : proprietaire, mais subSystem, language, filiere, niveau,
      // serie et createdAt sont IMMUABLES (Story 1.3 - ADR-006 etendu).
      // Champs editables : optedOutSubjects (Story 1.4), displayName/photoUrl
      // (Story 1.6), schoolId (Story 1.7), updatedAt (a chaque update qui passe
      // la regle).
      //
      // Story 1.5.d — Denormalisation 4 champs school* en 1 update partiel :
      // schoolId + schoolCity + schoolRegion + schoolName (ou tous null si
      // unlink). Pas de validation stricte coherence schoolCity <-> schools/
      // {schoolId}.city cote rules V1 : un client malveillant ne ferait que
      // falsifier SON propre profil (pas d'escalade securite, pas d'impact
      // ranking equipe). Re-evaluable Epic 5 si rankings utilisent ces champs
      // pour des recompenses (Cloud Function validation post-write a ajouter).
      //
      // Story 1.4 — Si optedOutSubjects est modifie dans la requete, il doit
      // etre un sous-ensemble de derivedSubjects (validation stricte cote
      // serveur). On utilise diff().affectedKeys() pour skip la validation
      // quand l'update ne touche pas optedOutSubjects (ex. set displayName
      // seul). toSet().difference() retourne l'ensemble des matieres en trop ;
      // size() == 0 garantit que toutes les matieres retirees existent dans
      // derivedSubjects.
      //
      // Story 1.15 — Clause symetrique pour pickedSubjects (mode panier
      // polymorphe free_with_obligatory / series_plus_optional / tve_picker).
      // pickedSubjectsValid() ci-dessus = version pragmatique MVP (subset
      // derivedSubjects).
      allow update: if isOwner(uid)
        && request.resource.data.subSystem == resource.data.subSystem
        && request.resource.data.language == resource.data.language
        && request.resource.data.filiere == resource.data.filiere
        && request.resource.data.niveau == resource.data.niveau
        && request.resource.data.serie == resource.data.serie
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          !('optedOutSubjects' in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.resource.data.optedOutSubjects is list
            && request.resource.data.optedOutSubjects.toSet().difference(
                 request.resource.data.derivedSubjects.toSet()
               ).size() == 0
          )
        )
        && (
          !('pickedSubjects' in request.resource.data.diff(resource.data).affectedKeys())
          || pickedSubjectsValid(request.resource.data)
        );

      // Delete : interdit cote client.
      // La suppression passe par Cloud Function `requestAccountDeletion`
      // (cf. BASE-DE-DONNEES.md § deletionRequestedAt).
      allow delete: if false;
    }

    // -----------------------------------------------------------------
    // _smoketest/{doc} — lecture/ecriture autorisee aux users authentifies
    // pour la story sentinelle E0 (Story 0.21).
    // TODO: remove after E0 sentinel validated (Story 0.21 ou debut E1).
    // -----------------------------------------------------------------
    match /_smoketest/{doc} {
      allow read, write: if request.auth != null;
    }

    // -----------------------------------------------------------------
    // Catalogue scolaire — 6 collections (Story 1.1c, ADR-015)
    //
    // Lecture autorisee a tout utilisateur authentifie (anonyme inclus).
    // Ecriture interdite cote client : seul le script Python externe
    // `scripts/firebase_seed/seed_catalogue.py` (Story 1.1b, avec
    // service-account.json) ou la Firebase Console admin peut ecrire.
    //
    // Schema autoritatif : doc/partage/BASE-DE-DONNEES.md
    // § « Catalogue scolaire (6 collections — Story 1.1a) »
    // -----------------------------------------------------------------
    match /filieres/{filiereId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /niveaux/{niveauId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /series/{serieId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /exam_targets/{examTargetId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /derivation_rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // schools/{schoolId} — catalogue d'ecoles (Story 1.7, FR-6)
    //
    // Lecture par tout user authentifie (le catalogue est public).
    // Ecriture interdite cote client : seul l'admin (via Console) peut
    // valider une ecole (poser isValidated = true) ou ajouter un doc.
    //
    // Story 1.5.c — La sous-collection requests/ est SUPPRIMEE. Les demandes
    // d'ajout vivent maintenant dans la collection racine school_requests/
    // (cf. match /school_requests/{requestId} plus bas).
    // -----------------------------------------------------------------
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // school_requests/{requestId} — demandes d'ajout d'ecole (Story 1.5.c)
    //
    // Collection racine (vs sous-collection schools/{id}/requests Story 1.7
    // POC supprimee). Permet :
    //   - Admin lit toutes les demandes pending dans Firebase Console en 1 read
    //   - Read self : utilisateur peut suivre SES demandes (futur ecran)
    //     via query where('requestedBy', '==', auth.uid)
    //   - Rules simples (1 path explicite, pas de wildcard dynamique)
    //
    // Schema autoritatif : doc/partage/BASE-DE-DONNEES.md
    // § school_requests/{requestId}
    //
    // Cost-benefit : ~42 demandes/mois @10k users (5% taux demande × 10k
    // onboardings/an / 12 mois). Storage negligeable. Read/jour admin = 1-2
    // polls Console manuels.
    // -----------------------------------------------------------------
    match /school_requests/{requestId} {
      // Create par owner avec champs valides + status force a 'pending'
      // (anti-escalade : un client malveillant ne peut pas creer une demande
      // deja 'approved').
      allow create: if request.auth != null
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 200
        && request.resource.data.city is string
        && request.resource.data.city.size() >= 2
        && request.resource.data.city.size() <= 100
        && request.resource.data.status == 'pending'
        && (
          !('subSystem' in request.resource.data)
          || request.resource.data.subSystem in ['francophone', 'anglophone', 'both']
        )
        && (
          !('region' in request.resource.data)
          || (request.resource.data.region is string
              && request.resource.data.region.size() <= 100)
        );

      // Read self : l'utilisateur peut lire UNIQUEMENT ses propres demandes.
      // Permet un futur ecran « Mes demandes » avec query
      // where('requestedBy', '==', auth.uid).
      allow read: if request.auth != null
        && resource.data.requestedBy == request.auth.uid;

      // Update/delete : interdit cote client. La moderation passe par Cloud
      // Function (futur Epic admin) ou par Firebase Console admin manuellement.
      allow update, delete: if false;
    }
  }
}
