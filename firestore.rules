// =====================================================================
// Valide School — Firestore Security Rules (Story 0.9, P0)
// =====================================================================
//
// References :
//   - NFR-9 : "le vrai verrou est dans les regles Firestore" (CLAUDE.md)
//   - ADR-003 : Firebase full backend
//   - doc/partage/BASE-DE-DONNEES.md § users/{uid}
//
// Phase actuelle : P0 squelette minimal. Sera enrichi story par story
// (subscriptions, sessions Mode 2 premium-gated, etc.).
//
// Deploiement : `firebase deploy --only firestore:rules --project=valide-edu`
// Tests : `cd test/rules && npm test` (necessite firebase emulator demarre)
// =====================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------
    // Default deny — toute path non matchee ci-dessous est refusee.
    // Firestore deny par defaut deja, mais on l'expose pour lisibilite.
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------
    // users/{uid} — profil eleve, self-only (refactor E1bis-9 + E1bis-7)
    //
    // Schema E1bis (refactor du legacy Epic 1 filiere/niveau/serie ->
    // trackId/levelId/streamId) :
    //   - uid : string (redondant avec doc ID)
    //   - subSystem : 'francophone' | 'anglophone' (immuable)
    //   - language : 'fr' | 'en' (immuable, derive du subSystem)
    //   - trackId : 'generale' | 'technique' (immuable)
    //   - levelId : string (immuable apres creation)
    //   - streamId : string | null (peut etre null pour niveaux sans serie)
    //   - pickedSubjects : list<string>
    //   - displayName : string
    //   - phoneNumber : string | null (format +237XXXXXXXXX)
    //   - schoolId : string | null
    //   - schoolName : string | null
    //   - pendingSchoolRequestId : string | null
    //   - authProvider : 'google' | 'apple' | 'guest'
    //   - isAnonymous : bool
    //   - createdAt / updatedAt : timestamp (servertimestamp)
    //
    // Schema autoritatif : doc/partage/BASE-DE-DONNEES.md § users/{uid}
    // -----------------------------------------------------------------
    match /users/{uid} {

      // Lecture : uniquement le proprietaire
      allow read: if isOwner(uid);

      // Creation : proprietaire + champs critiques valides
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.subSystem in ['francophone', 'anglophone']
        && request.resource.data.language in ['fr', 'en']
        && request.resource.data.trackId in ['generale', 'technique']
        && request.resource.data.levelId is string
        && request.resource.data.levelId.size() > 0
        && request.resource.data.pickedSubjects is list
        && request.resource.data.displayName is string
        && request.resource.data.authProvider in ['google', 'apple', 'guest']
        && request.resource.data.isAnonymous is bool;

      // Update : proprietaire + immutabilite conditionnelle des champs
      // structurants (ADR-006 etendu E1bis).
      //
      // Pattern : pour chaque champ, "si le resource a deja une valeur,
      // alors la nouvelle valeur doit etre identique ; sinon permettre
      // d'ajouter le champ". Ca permet la migration des docs legacy
      // (Epic 1 stockait filiere/niveau/serie, E1bis ecrit
      // trackId/levelId/streamId — les docs migres ajoutent les nouveaux
      // champs sans casser).
      allow update: if isOwner(uid)
        && (!('subSystem' in resource.data) || request.resource.data.subSystem == resource.data.subSystem)
        && (!('language' in resource.data) || request.resource.data.language == resource.data.language)
        && (!('trackId' in resource.data) || request.resource.data.trackId == resource.data.trackId)
        && (!('levelId' in resource.data) || request.resource.data.levelId == resource.data.levelId)
        && (!('streamId' in resource.data) || request.resource.data.streamId == resource.data.streamId)
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);

      // Delete : autorise pour le proprietaire (self-delete). Permet le
      // bouton dev "Supprimer compte + tout vider" (DevAuditFab) et la
      // future demande de suppression GDPR cote user.
      //
      // Note : on supprime UNIQUEMENT le doc users/{uid}. Les sous-collections
      // eventuelles (school_requests, sessions, ...) ne sont pas cascade-delete
      // par Firestore — une Cloud Function `requestAccountDeletion` (futur
      // Epic admin) fera le menage complet cote serveur.
      allow delete: if isOwner(uid);
    }

    // -----------------------------------------------------------------
    // _smoketest/{doc} — lecture/ecriture autorisee aux users authentifies
    // pour la story sentinelle E0 (Story 0.21).
    // TODO: remove after E0 sentinel validated (Story 0.21 ou debut E1).
    // -----------------------------------------------------------------
    match /_smoketest/{doc} {
      allow read, write: if request.auth != null;
    }

    // -----------------------------------------------------------------
    // Catalogue scolaire — 6 collections (Story 1.1c, ADR-015)
    //
    // Lecture autorisee a tout utilisateur authentifie (anonyme inclus).
    // Ecriture interdite cote client : seul le script Python externe
    // `scripts/firebase_seed/seed_catalogue.py` (Story 1.1b, avec
    // service-account.json) ou la Firebase Console admin peut ecrire.
    //
    // Schema autoritatif : doc/partage/BASE-DE-DONNEES.md
    // § « Catalogue scolaire (6 collections — Story 1.1a) »
    // -----------------------------------------------------------------
    match /filieres/{filiereId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /niveaux/{niveauId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /series/{serieId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /exam_targets/{examTargetId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /derivation_rules/{ruleId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // schools/{schoolId} — catalogue d'ecoles (Story 1.7, FR-6)
    //
    // Lecture par tout user authentifie (le catalogue est public).
    // Ecriture interdite cote client : seul l'admin (via Console) peut
    // valider une ecole (poser isValidated = true) ou ajouter un doc.
    //
    // Story 1.5.c — La sous-collection requests/ est SUPPRIMEE. Les demandes
    // d'ajout vivent maintenant dans la collection racine school_requests/
    // (cf. match /school_requests/{requestId} plus bas).
    // -----------------------------------------------------------------
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -----------------------------------------------------------------
    // school_requests/{requestId} — demandes d'ajout d'ecole (Story 1.5.c)
    //
    // Collection racine (vs sous-collection schools/{id}/requests Story 1.7
    // POC supprimee). Permet :
    //   - Admin lit toutes les demandes pending dans Firebase Console en 1 read
    //   - Read self : utilisateur peut suivre SES demandes (futur ecran)
    //     via query where('requestedBy', '==', auth.uid)
    //   - Rules simples (1 path explicite, pas de wildcard dynamique)
    //
    // Schema autoritatif : doc/partage/BASE-DE-DONNEES.md
    // § school_requests/{requestId}
    //
    // Cost-benefit : ~42 demandes/mois @10k users (5% taux demande × 10k
    // onboardings/an / 12 mois). Storage negligeable. Read/jour admin = 1-2
    // polls Console manuels.
    // -----------------------------------------------------------------
    match /school_requests/{requestId} {
      // Create par owner avec champs valides + status force a 'pending'
      // (anti-escalade : un client malveillant ne peut pas creer une demande
      // deja 'approved').
      allow create: if request.auth != null
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 200
        && request.resource.data.city is string
        && request.resource.data.city.size() >= 2
        && request.resource.data.city.size() <= 100
        && request.resource.data.status == 'pending'
        && (
          !('subSystem' in request.resource.data)
          || request.resource.data.subSystem in ['francophone', 'anglophone', 'both']
        )
        && (
          !('region' in request.resource.data)
          || (request.resource.data.region is string
              && request.resource.data.region.size() <= 100)
        );

      // Read self : l'utilisateur peut lire UNIQUEMENT ses propres demandes.
      // Permet un futur ecran « Mes demandes » avec query
      // where('requestedBy', '==', auth.uid).
      allow read: if request.auth != null
        && resource.data.requestedBy == request.auth.uid;

      // Update/delete : interdit cote client. La moderation passe par Cloud
      // Function (futur Epic admin) ou par Firebase Console admin manuellement.
      allow update, delete: if false;
    }
  }
}
